# Database
DATABASE_URL=sqlite+aiosqlite:///./fleet_manager.db
# DATABASE_URL=postgresql+asyncpg://fleet:fleet_secret@localhost:5432/fleet_manager

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=1883

# Authentication
JWT_SECRET=change-me-in-production

# OpenAI (optional — for LLM-based task planning)
OPENAI_API_KEY=

# Fleet settings
ROBOT_STATE_UPDATE_HZ=2.0
JOB_ALLOCATION_INTERVAL_SEC=5.0
